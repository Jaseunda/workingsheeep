      "type": "bulletListItem",
      "props": { "textColor": "default", "backgroundColor": "default", "textAlignment": "left" },
      "content": [
        { "type": "text", "text": "Vertical reading remains unchanged, so long documents still scroll naturally.", "styles": {} }
