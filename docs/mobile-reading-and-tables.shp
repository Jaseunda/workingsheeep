      "content": [
        { "type": "text", "text": "Sheeep keeps mobile reading usable by allowing horizontal scroll where content is naturally wide, instead of squeezing text into unreadable columns.", "styles": {} }
      ],
      "children": []
    },
    {
      "id": "m1",
      "type": "heading",
      "props": { "textColor": "default", "backgroundColor": "default", "textAlignment": "left", "level": 2 },
      "content": [
        { "type": "text", "text": ".shp and README Tables", "styles": {} }
      ],
      "children": []
    },
    {
      "id": "m2",
      "type": "bulletListItem",
      "props": { "textColor": "default", "backgroundColor": "default", "textAlignment": "left" },
      "content": [
        { "type": "text", "text": "Tables in BlockNote/ProseMirror wrappers can scroll horizontally on narrow screens.", "styles": {} }
      ],
      "children": []
    },
    {
      "id": "m3",
      "type": "bulletListItem",
      "props": { "textColor": "default", "backgroundColor": "default", "textAlignment": "left" },
      "content": [
        { "type": "text", "text": "Page spacing stays intact for readability; only the table region scrolls.", "styles": {} }
      ],
      "children": []
    },
    {
