      "props": { "textColor": "default", "backgroundColor": "default", "textAlignment": "left" },
      "content": [
        { "type": "text", "text": "DOCX pages keep natural page width (no forced fit-to-screen compression).", "styles": {} }
      ],
      "children": []
    },
    {
